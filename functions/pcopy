# Copy Root Filesystem (now with more parallel!)
function pcopy() {
	if [[ -d $1 ]]; then
		THREADS="24"
		rsync --no-motd -zr -f"+ */" -f"- *" $1/ $2/ 1>&3 2>&3
		cd $1; find . -type f -print0 | xargs -0 -n1 -P$THREADS -I% rsync -aqz --no-motd % $2/% 1>&3 2>&3
		rsync -HAXcqa --no-motd $1 $2 1>&3 2>&3 || return 1;
	else
		rsync -HAXcqa --no-motd $1 $2 1>&3 2>&3 || return 1;
	fi
}
