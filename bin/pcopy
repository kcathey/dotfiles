if [[ -d $1 ]]; then
  THREADS="24"
  echo "Moving folders"
  rsync --no-motd -zpogtr -f"+ */" -f"- *" $1/ $2/
  echo "Moving files"
  cd $1; find . -type f -print0 | xargs -0 -n1 -P$THREADS -I% rsync -az --no-motd % $2/%
  echo "final move"
  rsync -HAXca --no-motd $1 $2 || return 1;
else
  echo "Moving"
  rsync -HAXca --no-motd $1 $2 || return 1;
fi
